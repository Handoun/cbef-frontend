{
  "name": "my-messenger",
  "version": "1.0.0",
  "description": "My Messenger Desktop App",
  "author": "Handoun",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.example.messenger",
    "productName": "My Messenger",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^26.2.2",
    "electron-builder": "^24.6.0"
  }
}