{
  "name": "cbef-desktop",
  "version": "1.0.0",
  "description": "CBEF Desktop App",
  "author": "Handoun",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.cbef.desktop",
    "productName": "CBEF",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^26.2.2",
    "electron-builder": "^24.6.0"
  }
}
